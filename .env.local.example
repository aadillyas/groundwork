# Google Gemini API — get your free key at https://aistudio.google.com
# Free tier: 25 requests/day on Gemini 2.5 Pro (sufficient for dev + testing)
GEMINI_API_KEY=

# GitHub Personal Access Token — no special scopes needed
# Generate at https://github.com/settings/tokens
GITHUB_TOKEN=

# ─── Future provider swap ─────────────────────────────────────────────────────
# To switch LLM provider, update lib/llm.ts and replace the key above with:
# OPENROUTER_API_KEY=   (openrouter.ai — pay-as-you-go, many models)
# ANTHROPIC_API_KEY=    (console.anthropic.com — Claude Sonnet)
# OPENAI_API_KEY=       (platform.openai.com)
# For Ollama (local): no key needed, just update the base URL in lib/llm.ts
